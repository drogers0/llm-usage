{
  "manifest_version": 3,
  "name": "LLM Usage Fetcher",
  "version": "1.0",
  "description": "Fetches usage data from Claude and Codex for llm_usage scripts",
  "permissions": [
    "cookies",
    "webNavigation",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
